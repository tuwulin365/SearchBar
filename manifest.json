{
"update_url": "https://clients2.google.com/service/update2/crx",

  "name": "SearchBar",
  "version": "0.12.0",
  "manifest_version": 3,
  "description": "使用您最喜爱的搜索引擎的最有效方式。搜索选定文本，使用自定义快捷键等。",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["content.js"],
      "all_frames": true
    },
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["start.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "incognito": "split",
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "19": "icon19.png",
      "38": "icon38.png"
    },
    "default_title": "show/hide SearchBar",
    "default_popup": "popup.html"
  }
}